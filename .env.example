TELEGRAM_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
DEFAULT_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL=openrouter/free
DATABASE_URL=sqlite+aiosqlite:///data/kombain.db
CACHE_TTL_HOURS=24
CACHE_ENABLED=true
DAILY_REQUEST_LIMIT=50
HEALTH_ENABLED=true
HEALTH_PORT=8080
# Опционально для YouTube на Railway (обход bot-check):
# YOUTUBE_COOKIES_B64=<base64 от cookies.txt>
# YOUTUBE_PROXY=socks5://login:password@real-proxy.com:1080
LOG_LEVEL=INFO
